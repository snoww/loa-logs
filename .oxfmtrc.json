{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "trailingComma": "none",
  "tabWidth": 2,
  "printWidth": 120,
  "endOfLine": "crlf",
  "sortImports": true,
  "sortTailwindcss": {
    "stylesheet": "./src/app.css"
  },
  "svelte": true,
  "sortPackageJson": true,
  "ignorePatterns": [
    ".DS_Store",
    "node_modules",
    "/build",
    "/.svelte-kit",
    "/package",
    ".env",
    ".env.*",
    "!.env.example",
    "pnpm-lock.yaml",
    "package-lock.json",
    "yarn.lock",
    "/src/lib/constants/StatOrigin.json",
    "/src-tauri"
  ]
}
